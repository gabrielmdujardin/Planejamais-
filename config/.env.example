# ===========================================
# Planeja+ - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env.local e preencha os valores

# -------------------------------------------
# Supabase
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anonima-publica
SUPABASE_SERVICE_ROLE_KEY=sua-chave-de-servico-privada

# -------------------------------------------
# Jobs / Cron
# -------------------------------------------
# Token secreto para autenticação dos endpoints de jobs
JOBS_SECRET_TOKEN=seu-token-secreto-aleatorio

# -------------------------------------------
# Opcional - Analytics
# -------------------------------------------
# NEXT_PUBLIC_ANALYTICS_ID=seu-id-analytics

# -------------------------------------------
# Opcional - Vercel
# -------------------------------------------
# VERCEL_URL=https://seu-projeto.vercel.app

# -------------------------------------------
# Opcional - Email (se implementar notificações)
# -------------------------------------------
# SMTP_HOST=smtp.exemplo.com
# SMTP_PORT=587
# SMTP_USER=seu-usuario
# SMTP_PASS=sua-senha
# EMAIL_FROM=noreply@planeja.app
